{
  "pluginAlias": "HomeAssistantGarageDoor",
  "pluginType": "accessory",
  "singular": false,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "required": true,
        "default": "Garage Door"
      },
      "haUrl": {
        "title": "Home Assistant URL",
        "type": "string",
        "required": true,
        "placeholder": "http://homeassistant.local:8123"
      },
      "entityId": {
        "title": "Entity ID",
        "type": "string",
        "required": true,
        "placeholder": "switch.garage_relay"
      },
      "haToken": {
        "title": "Long-Lived Access Token",
        "type": "string",
        "required": true
      },
      "pollInterval": {
        "title": "Poll Interval (seconds)",
        "type": "integer",
        "default": 30,
        "minimum": 5
      }
    }
  }
}
