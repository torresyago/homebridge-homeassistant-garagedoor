{
  "pluginAlias": "HomeAssistantGarageDoor",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Platform Name",
        "type": "string",
        "default": "HA Garage Door"
      },
      "devices": {
        "title": "Garage Doors",
        "type": "array",
        "items": {
          "title": "Garage Door",
          "type": "object",
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "required": true,
              "default": "Garage Door",
              "description": "Display name in the Home app"
            },
            "haUrl": {
              "title": "Home Assistant URL",
              "type": "string",
              "required": true,
              "placeholder": "http://homeassistant.local:8123"
            },
            "entityId": {
              "title": "Entity ID",
              "type": "string",
              "required": true,
              "placeholder": "switch.garage_relay"
            },
            "haToken": {
              "title": "Long-Lived Access Token",
              "type": "string",
              "required": true
            },
            "pollInterval": {
              "title": "Poll Interval (seconds)",
              "type": "integer",
              "default": 30,
              "minimum": 5
            }
          }
        }
      }
    }
  }
}
